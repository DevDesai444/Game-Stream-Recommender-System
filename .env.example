# Steam Web API
STEAM_API_KEY=replace-with-your-key
STEAM_INGEST_CONCURRENCY=64
STEAM_INGEST_USER_TARGET=50000

# Spark
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
DELTA_ROOT=./data/delta

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_REGISTRY_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=gamereco

# Postgres / pgvector
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gamereco
POSTGRES_USER=gamereco
POSTGRES_PASSWORD=gamereco

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=900

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
